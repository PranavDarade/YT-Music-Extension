{
    "manifest_version": 3,
    "name": "Youtube Music Queue Enhancer",
    "description": "Custom shuffle, smarter add-to-queue, and persistent queue for YT Music.",
    "version": "1.0",
    "permissions": [
        "scripting",
        "storage",
        "activeTab"
    ],
    "host_permissions": [
        "https://music.youtube.com/*"
    ],
    "content_scripts": [
        {
            "matches": ["https://music.youtube.com/*"],
            "js": ["content.js"],
            "run_at": "document_idle"
        }
    ]
}